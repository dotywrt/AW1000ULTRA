/dts-v1/;

/ {
	model = "AW1000_Ultra";
	compatible = "mediatek,evb6890v1_64_cpe\0mediatek,mt6890\0telstra,meteor2";
	interrupt-parent = <0x01>;
	#address-cells = <0x02>;
	#size-cells = <0x02>;

	chosen {
		bootargs = "console=tty0 console=ttyS0,921600n1 \t\tinit=/etc/preinit root=/dev/mmcblk0p32 mmcdev=179:14 rootwait \t\tloglevel=8 mtdpath=/dev/mmcblk0p14 \t\tandroidboot.selinux=permissive androidboot.hardware=mt6890 \t\tinitcall_debug=1 page_owner=on";
		atag,videolfb-fb_base_l = "~`P";
		atag,videolfb-fb_base_h = <0x00>;
		atag,videolfb-islcmfound = <0x01>;
		atag,videolfb-islcm_inited = <0x00>;
		atag,videolfb-fps = <0x1770>;
		atag,videolfb-vramSize = <0x1be0000>;
		atag,videolfb-lcmname = "nt35595_fhd_dsi_cmd_truly_nt50358_drv";
		phandle = <0xb9>;
	};

	psci {
		compatible = "arm,psci-0.2";
		method = "smc";
	};

	gpio_leds {
		compatible = "gpio-leds";
		phandle = <0xba>;

		led0 {
			label = "internet:single";
			gpios = <0x02 0x04 0x00>;
			linux,default-trigger = "none";
			default-state = "off";
		};

		led1 {
			label = "wifi:green";
			gpios = <0x02 0x05 0x00>;
			linux,default-trigger = "none";
			default-state = "off";
		};

		led2 {
			label = "status:green";
			gpios = <0x02 0x08 0x00>;
			linux,default-trigger = "none";
			default-state = "off";
		};

		led3 {
			label = "phone:green";
			gpios = <0x02 0x15 0x00>;
			linux,default-trigger = "none";
			default-state = "off";
		};

		led4 {
			label = "5g:signal";
			gpios = <0x02 0x16 0x00>;
			linux,default-trigger = "none";
			default-state = "off";
		};

		led5 {
			label = "signal:red";
			gpios = <0x02 0x19 0x00>;
			linux,default-trigger = "none";
			default-state = "off";
		};

		led6 {
			label = "phone:red";
			gpios = <0x02 0x1a 0x00>;
			linux,default-trigger = "none";
			default-state = "off";
		};

		led7 {
			label = "signal:green";
			gpios = <0x02 0x1b 0x00>;
			linux,default-trigger = "none";
			default-state = "off";
		};

		led8 {
			label = "status:red";
			gpios = <0x02 0x1c 0x00>;
			linux,default-trigger = "none";
			default-state = "off";
		};

		led9 {
			label = "wifi:red";
			gpios = <0x02 0x1d 0x00>;
			linux,default-trigger = "none";
			default-state = "off";
		};
	};

	pwmleds {
		compatible = "mediatek,pwm-leds";

		backlight {
			label = "lcd-backlight";
			pwms = <0x03 0x00 0x99d9>;
			max-brightness = <0xff>;
			pwm-names = "lcd-backlight";
		};
	};

	opp_table0 {
		compatible = "operating-points-v2";
		opp-shared;
		phandle = <0x04>;

		opp0 {
			opp-hz = <0x00 0x1dcd6500>;
			opp-microvolt = <0x9eb10>;
		};

		opp1 {
			opp-hz = <0x00 0x23c34600>;
			opp-microvolt = <0x9eb10>;
		};

		opp2 {
			opp-hz = <0x00 0x28c50300>;
			opp-microvolt = <0xa344e>;
		};

		opp3 {
			opp-hz = <0x00 0x2dc6c000>;
			opp-microvolt = <0xa7d8c>;
		};

		opp4 {
			opp-hz = <0x00 0x30e03500>;
			opp-microvolt = <0xaae60>;
		};

		opp5 {
			opp-hz = <0x00 0x37d97c40>;
			opp-microvolt = <0xb1008>;
		};

		opp6 {
			opp-hz = <0x00 0x3f2e5100>;
			opp-microvolt = <0xb71b0>;
		};

		opp7 {
			opp-hz = <0x00 0x43977780>;
			opp-microvolt = <0xbbaee>;
		};

		opp8 {
			opp-hz = <0x00 0x4bfef4c0>;
			opp-microvolt = "\0\f5";
		};

		opp9 {
			opp-hz = <0x00 0x52abf0c0>;
			opp-microvolt = <0xc96a8>;
		};

		opp10 {
			opp-hz = <0x00 0x59682f00>;
			opp-microvolt = <0xcf850>;
		};

		opp11 {
			opp-hz = <0x00 0x634d2480>;
			opp-microvolt = <0xdbba0>;
		};

		opp12 {
			opp-hz = <0x00 0x684ee180>;
			opp-microvolt = <0xe1d48>;
		};

		opp13 {
			opp-hz = <0x00 0x6d415c40>;
			opp-microvolt = <0xe7ef0>;
		};

		opp14 {
			opp-hz = <0x00 0x7233d700>;
			opp-microvolt = <0xee098>;
		};

		opp15 {
			opp-hz = <0x00 0x77359400>;
			opp-microvolt = <0xf4240>;
		};
	};

	cpus {
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x00>;
			enable-method = "psci";
			clock-frequency = <0x65633340>;
			operating-points-v2 = <0x04>;
			cpu-idle-states = <0x05 0x06 0x07>;
			dynamic-power-coefficient = <0x55>;
			#cooling-cells = <0x02>;
			phandle = <0x08>;
		};

		cpu@001 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x100>;
			enable-method = "psci";
			clock-frequency = <0x65633340>;
			operating-points-v2 = <0x04>;
			cpu-idle-states = <0x05 0x06 0x07>;
			dynamic-power-coefficient = <0x55>;
			#cooling-cells = <0x02>;
			phandle = <0x09>;
		};

		cpu@002 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x200>;
			enable-method = "psci";
			clock-frequency = <0x65633340>;
			operating-points-v2 = <0x04>;
			cpu-idle-states = <0x05 0x06 0x07>;
			dynamic-power-coefficient = <0x55>;
			#cooling-cells = <0x02>;
			phandle = <0x0a>;
		};

		cpu@003 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x300>;
			enable-method = "psci";
			clock-frequency = <0x65633340>;
			operating-points-v2 = <0x04>;
			cpu-idle-states = <0x05 0x06 0x07>;
			dynamic-power-coefficient = <0x55>;
			#cooling-cells = <0x02>;
			phandle = <0x0b>;
		};

		cpu-map {

			cluster0 {

				core0 {
					cpu = <0x08>;
				};

				core1 {
					cpu = <0x09>;
				};

				core2 {
					cpu = <0x0a>;
				};

				core3 {
					cpu = <0x0b>;
				};
			};
		};

		idle-states {
			entry-method = "arm,psci";

			cpuoff_l {
				compatible = "mediatek,idle-state";
				arm,psci-suspend-param = <0x10001>;
				local-timer-stop;
				entry-latency-us = <0x32>;
				exit-latency-us = <0x64>;
				min-residency-us = <0x640>;
				phandle = <0x05>;
			};

			clusteroff_l {
				compatible = "mediatek,idle-state";
				arm,psci-suspend-param = <0x1010001>;
				local-timer-stop;
				entry-latency-us = <0x64>;
				exit-latency-us = <0xfa>;
				min-residency-us = <0x834>;
				phandle = <0x06>;
			};

			mcusysoff {
				compatible = "mediatek,idle-state";
				arm,psci-suspend-param = <0x1010002>;
				local-timer-stop;
				entry-latency-us = <0x12c>;
				exit-latency-us = <0x4b0>;
				min-residency-us = <0xa28>;
				phandle = <0x07>;
			};
		};
	};

	pmu {
		compatible = "arm,armv8-pmuv3";
		interrupt-parent = <0x01>;
		interrupts = <0x01 0x07 0x04>;
	};

	dsu-pmu-0 {
		compatible = "arm,dsu-pmu";
		interrupts = <0x00 0x12 0x04>;
		cpus = <0x08 0x09 0x0a 0x0b>;
	};

	dvfsp@0011bc00 {
		compatible = "mediatek,mcupm-dvfsp";
		reg = <0x00 0x11bc00 0x00 0x1400>;
		nvmem = <0x0c>;
		nvmem-names = "mtk_efuse";
		nvmem-cells = <0x0d>;
		nvmem-cell-names = "efuse_segment_cell";
		phandle = <0xbb>;
	};

	leakage@1100b000 {
		compatible = "mediatek,leakage";
		reg = <0x00 0x1100b000 0x00 0x1000>;
		interrupts = <0x00 0x7d 0x08>;
		nvmem = <0x0c>;
		nvmem-names = "mtk_efuse";
		nvmem-cells = <0x0d>;
		nvmem-cell-names = "efuse_segment_cell";
		n-domain = <0x07>;
		domain = "LL\0CCI\0VCORE\0MODEM_NR\0VSRAM_CPULL\0VSRAM_MODEM\0VCORE_OFF";
		LL = <0x2ee 0x1e 0x224 0x00 0x00 0x01>;
		CCI = <0x2ee 0x1e 0x220 0x18 0x00 0x01>;
		VCORE = <0x2ee 0x1e 0x21c 0x10 0x00 0x01>;
		MODEM_NR = <0x339 0x1e 0x21c 0x08 0x00 0x01>;
		VSRAM_CPULL = <0x2ee 0x1e 0x228 0x10 0x00 0x01>;
		VSRAM_MODEM = <0x339 0x1e 0x22c 0x00 0x00 0x01>;
		VCORE_OFF = <0x226 0x1e 0x224 0x10 0x00 0x01>;
	};

	memory {
		device_type = "memory";
		reg = <0x00 0x40000000 0x00 0x3e605000>;
	};

	wed@15010000 {
		compatible = "mediatek,wed";
		wed_num = <0x02>;
		pci_slot_map = <0x00 0x01>;
		reg = <0x00 0x15010000 0x00 0x1000 0x00 0x15011000 0x00 0x1000>;
		interrupt-parent = <0x01>;
		interrupts = <0x00 0x196 0x04 0x00 0x197 0x04>;
		phandle = <0xbc>;
	};

	wed2@15011000 {
		compatible = "mediatek,wed2";
		wed_num = <0x02>;
		reg = <0x00 0x15010000 0x00 0x1000 0x00 0x15011000 0x00 0x1000>;
		interrupt-parent = <0x01>;
		interrupts = <0x00 0x196 0x04 0x00 0x197 0x04>;
		phandle = <0xbd>;
	};

	wdma@15102800 {
		compatible = "mediatek,wed-wdma";
		reg = <0x00 0x15102800 0x00 0x400 0x00 0x15102c00 0x00 0x400>;
		interrupt-parent = <0x01>;
		interrupts = <0x00 0xd8 0x04 0x00 0xd9 0x04 0x00 0xda 0x04 0x00 0xdb 0x04 0x00 0xdc 0x04 0x00 0xdd 0x04>;
		phandle = <0xbe>;
	};

	ap2woccif@151A9000 {
		compatible = "mediatek,ap2woccif";
		reg = <0x00 0x151a9000 0x00 0x1000 0x00 0x151ab000 0x00 0x1000>;
		interrupt-parent = <0x01>;
		interrupts = <0x00 0x19e 0x04 0x00 0x19f 0x04>;
		phandle = <0xbf>;
	};

	wocpu@15180000 {
		compatible = "mediatek,wocpu_sysram";
		reg = <0x00 0x15180000 0x00 0x8000>;
		shared = <0x01>;
		phandle = <0xc0>;
	};

	wocpu_dlm@1518E000 {
		compatible = "mediatek,wocpu_dlm";
		reg = <0x00 0x1518e000 0x00 0x2000 0x00 0x15192000 0x00 0x2000>;
		resets = <0x0e 0x00>;
		reset-names = "wocpu_rst";
		phandle = <0xc1>;
	};

	wocpu_boot@15194000 {
		compatible = "mediatek,wocpu_boot";
		reg = <0x00 0x15194000 0x00 0x1000>;
		phandle = <0xc2>;
	};

	pcie_mirror@10201000 {
		compatible = "mediatek,pcie-mirror";
		reg = <0x00 0x10201000 0x00 0x1000>;
		phandle = <0xc3>;
	};

	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;
		phandle = <0xc4>;

		reserve-memory-medmcu_share {
			compatible = "mediatek,reserve-memory-medmcu_share";
			no-map;
			size = <0x00 0x328700>;
			alignment = <0x00 0x1000000>;
			alloc-ranges = <0x00 0x60000000 0x00 0x10000000>;
		};

		gps-reserve-memory {
			compatible = "mediatek,gps-reserve-memory";
			no-map;
			size = <0x00 0x60000>;
			alignment = <0x00 0x10000>;
			alloc-ranges = <0x00 0x40000000 0x00 0x80000000>;
			phandle = <0x85>;
		};

		reserve-memory-mcupm_share {
			compatible = "mediatek,reserve-memory-mcupm_share";
			no-map;
			status = "okay";
			size = <0x00 0x210000>;
			alignment = <0x00 0x10000>;
			alloc-ranges = <0x00 0x40000000 0x00 0x60000000>;
		};

		reserve-memory-sspm_share {
			compatible = "mediatek,reserve-memory-sspm_share";
			no-map;
			status = "okay";
			size = <0x00 0x210000>;
			alignment = <0x00 0x10000>;
			alloc-ranges = <0x00 0x40000000 0x00 0x60000000>;
		};

		wocpu0_emi@50000000 {
			compatible = "mediatek,wocpu0_emi";
			no-map;
			reg = <0x00 0x50000000 0x00 0x80000>;
			shared = <0x00>;
			phandle = <0xc5>;
		};

		wocpu1_emi@50040000 {
			compatible = "mediatek,wocpu1_emi";
			no-map;
			reg = <0x00 0x50080000 0x00 0x80000>;
			shared = <0x00>;
			phandle = <0xc6>;
		};

		wocpu_data@50100000 {
			compatible = "mediatek,wocpu_data";
			no-map;
			reg = <0x00 0x50100000 0x00 0x180000>;
			shared = <0x01>;
			phandle = <0xc7>;
		};
	};

	interrupt-controller {
		compatible = "arm,gic-v3";
		#interrupt-cells = <0x03>;
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		#redistributor-regions = <0x01>;
		interrupt-parent = <0x01>;
		interrupt-controller;
		reg = <0x00 0xc000000 0x00 0x40000 0x00 0xc040000 0x00 0x200000>;
		interrupts = <0x01 0x09 0x04>;
		phandle = <0x01>;
	};

	clkao {
		compatible = "simple-bus";
		status = "okay";
		phandle = <0xc8>;

		bring-up {
			compatible = "mediatek,clk-bring-up";
			clocks = <0x0f 0x6c 0x0f 0x34 0x0f 0x65 0x0f 0x66 0x0f 0x67 0x0f 0x75 0x0f 0x61 0x0f 0x2d 0x0f 0x5c>;
		};

		bring-up-pd-sgmii_0_phy {
			compatible = "mediatek,scpsys-bring-up";
			power-domains = <0x10 0x0d>;
		};

		bring-up-pd-sgmii_0_top {
			compatible = "mediatek,scpsys-bring-up";
			power-domains = <0x10 0x0e>;
		};

		bring-up-pd-sgmii_1_phy {
			compatible = "mediatek,scpsys-bring-up";
			power-domains = <0x10 0x0f>;
		};

		bring-up-pd-sgmii_1_top {
			compatible = "mediatek,scpsys-bring-up";
			power-domains = <0x10 0x10>;
		};
	};

	clocks {

		clk_null {
			compatible = "fixed-clock";
			#clock-cells = <0x00>;
			clock-frequency = <0x00>;
			phandle = <0xc9>;
		};

		clk10m {
			compatible = "fixed-clock";
			#clock-cells = <0x00>;
			clock-frequency = <0x989680>;
			phandle = <0xca>;
		};

		clk26m {
			compatible = "fixed-clock";
			#clock-cells = <0x00>;
			clock-frequency = <0x18cba80>;
			phandle = <0x40>;
		};

		clk12m {
			compatible = "fixed-clock";
			#clock-cells = <0x00>;
			clock-frequency = <0xb71b00>;
			phandle = <0xcb>;
		};

		clk32k {
			compatible = "fixed-clock";
			#clock-cells = <0x00>;
			clock-frequency = <0x7d00>;
			phandle = <0x82>;
		};

		clk13m {
			compatible = "fixed-clock";
			#clock-cells = <0x00>;
			clock-frequency = <0xc65d40>;
			phandle = <0x4c>;
		};

		ulposc {
			compatible = "fixed-clock";
			#clock-cells = <0x00>;
			clock-frequency = <0xf7f4900>;
			phandle = <0xcc>;
		};
	};

	syscon@10000000 {
		compatible = "mediatek,mt6890-topckgen\0syscon";
		reg = <0x00 0x10000000 0x00 0x1000>;
		#clock-cells = <0x01>;
		phandle = <0x11>;
	};

	syscon@1000c000 {
		compatible = "mediatek,mt6890-apmixedsys\0syscon";
		reg = <0x00 0x1000c000 0x00 0xe00>;
		#clock-cells = <0x01>;
		phandle = <0xcd>;
	};

	syscon@0d0a0000 {
		compatible = "mediatek,mt6890-dbgsys_dem\0syscon";
		reg = <0x00 0xd0a0000 0x00 0x1000>;
		#clock-cells = <0x01>;
		phandle = <0xce>;
	};

	syscon@10001000 {
		compatible = "mediatek,mt6890-infracfg_ao\0syscon";
		reg = <0x00 0x10001000 0x00 0x1000>;
		#clock-cells = <0x01>;
		phandle = <0x0f>;
	};

	syscon@10003000 {
		compatible = "mediatek,mt6890-pericfg\0syscon";
		reg = <0x00 0x10003000 0x00 0x1000>;
		#clock-cells = <0x01>;
		phandle = <0xcf>;
	};

	power-controller@10006000 {
		compatible = "mediatek,mt6890-scpsys\0syscon";
		reg = <0x00 0x10006000 0x00 0x1000>;
		#power-domain-cells = <0x01>;
		infracfg = <0x0f>;
		clocks = <0x11 0xa7 0x11 0xa9 0x11 0xcf 0x11 0xd0 0x11 0xd1 0x11 0xd2 0x11 0xce 0x0f 0x35 0x12 0x11>;
		clock-names = "disp\0mfg\0snps_eth_312p5m_sel\0snps_eth_250m_sel\0snps_ptp_sel\0snps_rmii_sel\0eip97_sel\0audio\0disp-0";
		phandle = <0x10>;
	};

	syscon@10228000 {
		compatible = "mediatek,mt6890-gce\0syscon";
		reg = <0x00 0x10228000 0x00 0x1000>;
		#clock-cells = <0x01>;
		phandle = <0xd0>;
	};

	syscon@11210000 {
		compatible = "mediatek,mt6890-audsys\0syscon";
		reg = <0x00 0x11210000 0x00 0x1000>;
		#clock-cells = <0x01>;
		phandle = <0x98>;
	};

	syscon@11c46000 {
		compatible = "mediatek,mt6890-imp_iic_wrap_e\0syscon";
		reg = <0x00 0x11c46000 0x00 0x1000>;
		#clock-cells = <0x01>;
		phandle = <0x56>;
	};

	syscon@13fbf000 {
		compatible = "mediatek,mt6890-mfgsys\0syscon";
		reg = <0x00 0x13fbf000 0x00 0x1000>;
		#clock-cells = <0x01>;
		phandle = <0x6b>;
	};

	syson@14000000 {
		compatible = "mediatek,mt6890-mmsys_config\0syscon";
		reg = <0x00 0x14000000 0x00 0x1000>;
		#clock-cells = <0x01>;
		phandle = <0x12>;
	};

	mtk_lpm {
		compatible = "mediatek,mtk-lpm";
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;
		suspend-method = "system";
		irq-remain = <0x13 0x14>;
		resource-ctrl = <0x15 0x16 0x17 0x18 0x19>;
		constraints = <0x1a 0x1b 0x1c>;
		phandle = <0xd1>;

		lpm_sysram@0011b500 {
			compatible = "mediatek,lpm-sysram";
			reg = <0x00 0x11b500 0x00 0x300>;
			phandle = <0xd2>;
		};

		irq-remain-list {

			edge_keypad {
				target = <0x1d>;
				value = <0x01 0x00 0x00 0x04>;
				phandle = <0x13>;
			};

			edge_mdwdt {
				target = <0x1e>;
				value = <0x01 0x00 0x00 0x2000000>;
				phandle = <0x14>;
			};
		};

		resource-ctrl-list {

			bus26m {
				id = <0x00>;
				value = <0x00>;
				phandle = <0x15>;
			};

			infra {
